{
  "name": "fortawesome/fontawesome-elementor-addon",
  "description": "Official Font Awesome Elementor Addon.",
  "keywords": [
    "font awesome",
    "font-awesome",
    "elementor",
    "icon",
    "icons",
    "webfont",
    "svg"
  ],
  "homepage": "https://fontawesome.com",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Font Awesome"
    }
  ],
  "support": {
    "email": "hello@fontawesome.com"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10.2",
    "wp-coding-standards/wpcs": "^3.1.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1",
    "phpunit/phpunit": "^9",
    "yoast/phpunit-polyfills": "^1.1",
    "yoast/wp-test-utils": "^1.0"
  },
  "archive": {
    "exclude": [
      "phpcs.xml"
    ]
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml",
    "phpcbf": "phpcbf --standard=phpcs.xml"
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "symfony/flex": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require": {
    "fortawesome/wordpress-fontawesome-lib": "*"
  },
  "autoload": {
    "psr-4": {
      "FontAwesomeElementorAddon\\": "includes/"
    },
    "classmap": []
  },
  "repositories": [
    {
      "type": "path",
      "url": "../wordpress-fontawesome-lib",
      "options": {
        "symlink": true
      }
    }
  ]
}
