#!/bin/bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PLUGIN_DIR="$(realpath "$DIR/../plugin")"
DIST_DIR="$PLUGIN_DIR/wp-dist"

rm -fR $DIST_DIR
mkdir $DIST_DIR
wp-env run cli --env-cwd wp-content/plugins/fontawesome-elementor-addon composer install -- --no-dev --optimize-autoloader

for dir in "assets" "includes" "vendor"; do
  cp -r $PLUGIN_DIR/$dir $DIST_DIR/$dir
done

for file in $PLUGIN_DIR/*.php; do
  cp $file $DIST_DIR
done
